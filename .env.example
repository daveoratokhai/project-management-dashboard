# Copy this file to .env and adjust as needed.

# ---------------------------------------------------------------------------
# Database (Prisma)
# ---------------------------------------------------------------------------
# Local development still defaults to SQLite until the Postgres cutover.
# After the cutover this becomes a Supabase Postgres connection string.
#
#   DATABASE_URL  - pooled connection (Supabase port 6543, ?pgbouncer=true),
#                   used by the app at runtime.
#   DIRECT_URL    - direct connection (Supabase port 5432), used by
#                   `prisma migrate` / `prisma db push` only.
DATABASE_URL="file:./dev.db"
# DIRECT_URL="postgresql://postgres:...@db.<ref>.supabase.co:5432/postgres"

# ---------------------------------------------------------------------------
# Attachment storage
# ---------------------------------------------------------------------------
# STORAGE_DRIVER selects where attachment bytes live:
#   local    - on-disk ./uploads (default; local dev). Does NOT work on Vercel.
#   supabase - Supabase Storage (production).
STORAGE_DRIVER="local"

# Required only when STORAGE_DRIVER=supabase. The service role key is
# server-side only; never expose it to the browser.
# SUPABASE_URL="https://<ref>.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
# SUPABASE_STORAGE_BUCKET="attachments"

# ---------------------------------------------------------------------------
# WhatsApp / AI intake (Phase 3)
# ---------------------------------------------------------------------------
# OpenAI API key (platform.openai.com) for triaging inbound notes into tasks.
# OPENAI_API_KEY="sk-..."
# Twilio auth token, used to verify the X-Twilio-Signature on the webhook.
# TWILIO_AUTH_TOKEN="<twilio-auth-token>"

# ---------------------------------------------------------------------------
# Authentication (Supabase Auth + Google)
# ---------------------------------------------------------------------------
# Public Supabase project URL + anon key (safe to expose to the browser).
# The URL is the same as SUPABASE_URL above.
# NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# Who may sign in (comma-separated). Locked by default: if both are empty,
# nobody can sign in. Emails in AUTH_ADMIN_EMAILS become Admin on first login.
# AUTH_ALLOWED_EMAILS="alice@example.com,bob@example.com"
# AUTH_ADMIN_EMAILS="you@example.com"
