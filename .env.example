# Copy this file to .env and adjust as needed.

# ---------------------------------------------------------------------------
# Database (Prisma)
# ---------------------------------------------------------------------------
# Local development still defaults to SQLite until the Postgres cutover.
# After the cutover this becomes a Supabase Postgres connection string.
#
#   DATABASE_URL  - pooled connection (Supabase port 6543, ?pgbouncer=true),
#                   used by the app at runtime.
#   DIRECT_URL    - direct connection (Supabase port 5432), used by
#                   `prisma migrate` / `prisma db push` only.
DATABASE_URL="file:./dev.db"
# DIRECT_URL="postgresql://postgres:...@db.<ref>.supabase.co:5432/postgres"

# ---------------------------------------------------------------------------
# Attachment storage
# ---------------------------------------------------------------------------
# STORAGE_DRIVER selects where attachment bytes live:
#   local    - on-disk ./uploads (default; local dev). Does NOT work on Vercel.
#   supabase - Supabase Storage (production).
STORAGE_DRIVER="local"

# Required only when STORAGE_DRIVER=supabase. The service role key is
# server-side only; never expose it to the browser.
# SUPABASE_URL="https://<ref>.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
# SUPABASE_STORAGE_BUCKET="attachments"
