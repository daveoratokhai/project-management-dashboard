# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local database & secrets
/prisma/dev.db
/prisma/dev.db-journal
.env

# Uploaded attachment files
/uploads/*
!/uploads/.gitkeep

# Obsidian per-user UI state (keep app/appearance/core-plugins config)
vault/.obsidian/workspace.json
vault/.obsidian/graph.json
