// Prisma schema for the project management dashboard.
// Postgres (Supabase). DATABASE_URL is the transaction-mode pooler used at
// runtime; DIRECT_URL is the session-mode pooler used by prisma migrate.
// `Project.tags` stays a JSON-encoded String (parsed via parseTags) rather
// than a native Json column, to avoid churning the app code.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// A project shown on the dashboard and its detail page.
// Notes:
// - `status` is one of: active | inProgress | onHold (display labels derived in UI).
// - `tags` is a JSON-encoded array of tag keys (SQLite has no native JSON type,
//   so it is stored as a String and parsed in code).
// - `startDate` / `endDate` are stored as "YYYY-MM-DD" strings (or "" if unset)
//   and formatted for display.
model Project {
  id          String   @id @default(cuid())
  name        String
  repository  String   @default("")
  team        String   @default("")
  tech        String   @default("")
  status      String   @default("active")
  description String   @default("")
  startDate   String   @default("")
  endDate     String   @default("")
  tags        String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignees   Person[]      @relation("ProjectAssignees")
  attachments Attachment[]
  tasks       ProjectTask[]
}

// A person who can be assigned to projects.
model Person {
  id        String    @id @default(cuid())
  name      String
  avatarUrl String    @default("")
  fallback  String    @default("")
  projects  Project[] @relation("ProjectAssignees")
}

// An uploaded file belonging to a project. The bytes live on disk under
// ./uploads; this row holds the metadata.
model Attachment {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename   String
  storedName String
  size       Int      @default(0)
  mimeType   String   @default("")
  createdAt  DateTime @default(now())

  @@index([projectId])
}

// A row in a project's task list.
// `status` is one of: Completed | In Progress | Pending.
// `source` records where the task came from: "manual" (created in the UI) or
// a channel like "whatsapp" (created by AI intake). `reviewed` is false for
// AI-created tasks until a human confirms them; manual tasks default true.
model ProjectTask {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  category        String         @default("")
  status          String         @default("Pending")
  dueDate         String         @default("")
  order           Int            @default(0)
  source          String         @default("manual")
  reviewed        Boolean        @default(true)
  intakeMessageId String?        @unique
  intakeMessage   IntakeMessage? @relation(fields: [intakeMessageId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())

  @@index([projectId, order])
  @@index([reviewed])
}

// A raw inbound note captured from an intake channel (WhatsApp for now),
// before/around AI triage. Channel-agnostic so email or a web form can reuse
// the same triage + review path. The resulting task links back via
// `ProjectTask.intakeMessageId`.
// - `channel`: "whatsapp" | (future: "email" | "web")
// - `rawFrom`: sender identity (WhatsApp phone number)
// - `mediaJson`: JSON array of media references (voice notes; phase 4)
// - `transcript`: speech-to-text output (phase 4; "" for text messages)
// - `aiProjectId`: the project the LLM inferred (null = low confidence / Unsorted)
// - `aiConfidence`: 0..1 from the triage step
// - `status`: "created" (task made) | "failed" (triage/creation errored)
model IntakeMessage {
  id           String       @id @default(cuid())
  channel      String       @default("whatsapp")
  rawFrom      String       @default("")
  rawBody      String       @default("")
  mediaJson    String       @default("[]")
  transcript   String       @default("")
  aiProjectId  String?
  aiConfidence Float?
  status       String       @default("created")
  createdAt    DateTime     @default(now())

  task         ProjectTask?

  @@index([channel, createdAt])
}
